// backend/prisma/schema.prisma - VERSION NETTOYÉE
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ✅ ENUMS UNIFIÉS - Utilisation des valeurs UI partout
enum Role {
  admin      @map("admin")
  manager    @map("manager") 
  inspector  @map("inspector")
  multiplier @map("multiplier")
  guest      @map("guest")
  technician @map("technician")
  researcher @map("researcher")

  @@map("user_role")
}

enum SeedLevel {
  GO @map("GO")
  G1 @map("G1")
  G2 @map("G2")
  G3 @map("G3")
  G4 @map("G4")
  R1 @map("R1")
  R2 @map("R2")

  @@map("seed_level")
}

enum CropType {
  rice    @map("rice")
  maize   @map("maize")
  peanut  @map("peanut")
  sorghum @map("sorghum")
  cowpea  @map("cowpea")
  millet  @map("millet")
  wheat   @map("wheat")

  @@map("crop_type")
}

enum LotStatus {
  pending     @map("pending")
  certified   @map("certified")
  rejected    @map("rejected")
  in_stock    @map("in-stock")    // ✅ Utilise kebab-case en DB aussi
  sold        @map("sold")
  active      @map("active")
  distributed @map("distributed")

  @@map("lot_status")
}

enum ParcelStatus {
  available @map("available")
  in_use    @map("in-use")       // ✅ Utilise kebab-case en DB aussi
  resting   @map("resting")

  @@map("parcel_status")
}

enum ProductionStatus {
  planned     @map("planned")
  in_progress @map("in-progress") // ✅ Utilise kebab-case en DB aussi
  completed   @map("completed")
  cancelled   @map("cancelled")

  @@map("production_status")
}

enum ActivityType {
  soil_preparation @map("soil-preparation") // ✅ Utilise kebab-case en DB aussi
  sowing           @map("sowing")
  fertilization    @map("fertilization")
  irrigation       @map("irrigation")
  weeding          @map("weeding")
  pest_control     @map("pest-control")     // ✅ Utilise kebab-case en DB aussi
  harvest          @map("harvest")
  other            @map("other")

  @@map("activity_type")
}

enum ContractStatus {
  draft     @map("draft")
  active    @map("active")
  completed @map("completed")
  cancelled @map("cancelled")

  @@map("contract_status")
}

enum MultiplierStatus {
  active   @map("active")
  inactive @map("inactive")

  @@map("multiplier_status")
}

enum CertificationLevel {
  beginner     @map("beginner")
  intermediate @map("intermediate")
  expert       @map("expert")

  @@map("certification_level")
}

enum TestResult {
  pass @map("pass")
  fail @map("fail")

  @@map("test_result")
}

enum IssueType {
  disease    @map("disease")
  pest       @map("pest")
  weather    @map("weather")
  management @map("management")
  other      @map("other")

  @@map("issue_type")
}

enum IssueSeverity {
  low    @map("low")
  medium @map("medium")
  high   @map("high")

  @@map("issue_severity")
}

enum ReportType {
  production             @map("production")
  quality                @map("quality")
  inventory              @map("inventory")
  multiplier_performance @map("multiplier-performance")
  custom                 @map("custom")

  @@map("report_type")
}

// ✅ MODÈLES avec enums unifiés
model User {
  id              Int                  @id @default(autoincrement())
  name            String
  email           String               @unique
  password        String
  avatar          String?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  role            Role                 // ✅ Utilise enum unifié
  activities      ProductionActivity[]
  qualityControls QualityControl[]
  reports         Report[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Variety {
  id                Int                 @id @default(autoincrement())
  name              String
  description       String?
  maturityDays      Int
  yieldPotential    Float?
  resistances       String[]
  origin            String?
  releaseYear       Int?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  code              String              @unique
  cropType          CropType            // ✅ Utilise enum unifié
  contracts         Contract[]
  seedLots          SeedLot[]
  productionHistory ProductionHistory[] // ✅ AJOUTÉ: relation inverse pour ProductionHistory

  @@index([cropType])
  @@index([isActive])
  @@index([code])
  @@map("varieties")
}

model SeedLot {
  id              String           @id
  quantity        Int
  productionDate  DateTime         @db.Date
  expiryDate      DateTime?        @db.Date
  multiplierId    Int?
  parcelId        Int?
  batchNumber     String?
  parentLotId     String?
  notes           String?
  qrCode          String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  varietyId       Int
  level           SeedLevel        // ✅ Utilise enum unifié
  status          LotStatus        @default(pending) // ✅ Utilise enum unifié
  productions     Production[]
  qualityControls QualityControl[]
  multiplier      Multiplier?      @relation(fields: [multiplierId], references: [id])
  parcel          Parcel?          @relation(fields: [parcelId], references: [id])
  parentLot       SeedLot?         @relation("SeedLotGenealogy", fields: [parentLotId], references: [id])
  childLots       SeedLot[]        @relation("SeedLotGenealogy")
  variety         Variety          @relation(fields: [varietyId], references: [id])

  @@index([varietyId])
  @@index([status])
  @@index([level])
  @@map("seed_lots")
}

model QualityControl {
  id              Int        @id @default(autoincrement())
  lotId           String
  controlDate     DateTime   @db.Date
  germinationRate Float
  varietyPurity   Float
  moistureContent Float?
  seedHealth      Float?
  observations    String?
  inspectorId     Int
  testMethod      String?
  laboratoryRef   String?
  certificateUrl  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  result          TestResult // ✅ Utilise enum unifié
  inspector       User       @relation(fields: [inspectorId], references: [id])
  seedLot         SeedLot    @relation(fields: [lotId], references: [id])

  @@index([result])
  @@index([lotId])
  @@map("quality_controls")
}

model Multiplier {
  id                 Int                  @id @default(autoincrement())
  name               String
  code               String?              @unique
  status             MultiplierStatus     @default(active)
  address            String
  latitude           Float
  longitude          Float
  yearsExperience    Int
  certificationLevel CertificationLevel
  specialization     CropType[]
  phone              String?
  email              String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  contracts          Contract[]
  seedLots           SeedLot[]
  productions        Production[]
  parcels            Parcel[]
  history            ProductionHistory[]

  @@index([status])
  @@index([certificationLevel])
  @@index([isActive])
  @@map("multipliers")
}

model Parcel {
  id               Int            @id @default(autoincrement())
  name             String?
  area             Float
  latitude         Float
  longitude        Float
  status           ParcelStatus   @default(available)
  soilType         String?
  irrigationSystem String?
  address          String?
  multiplierId     Int?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  multiplier       Multiplier?    @relation(fields: [multiplierId], references: [id])
  seedLots         SeedLot[]
  productions      Production[]
  soilAnalyses     SoilAnalysis[]
  previousCrops    PreviousCrop[]
  contracts        Contract[]     // ✅ AJOUTÉ: relation inverse pour Contract

  @@index([status])
  @@index([multiplierId])
  @@index([isActive])
  @@map("parcels")
}

model Production {
  id                String               @id @default(cuid())
  lotId             String
  multiplierId      Int
  parcelId          Int
  startDate         DateTime             @db.Date
  endDate           DateTime?            @db.Date
  sowingDate        DateTime?            @db.Date
  harvestDate       DateTime?            @db.Date
  plannedQuantity   Int?
  actualYield       Int?
  status            ProductionStatus     @default(planned)
  notes             String?
  weatherConditions String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  seedLot           SeedLot              @relation(fields: [lotId], references: [id])
  multiplier        Multiplier           @relation(fields: [multiplierId], references: [id])
  parcel            Parcel               @relation(fields: [parcelId], references: [id])
  activities        ProductionActivity[]
  issues            ProductionIssue[]
  weatherData       WeatherData[]

  @@index([status])
  @@index([lotId])
  @@index([multiplierId])
  @@index([parcelId])
  @@map("productions")
}

model ProductionActivity {
  id           Int              @id @default(autoincrement())
  productionId String
  type         ActivityType
  activityDate DateTime         @db.Date
  description  String
  personnel    String[]
  notes        String?
  userId       Int
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  production   Production       @relation(fields: [productionId], references: [id])
  user         User             @relation(fields: [userId], references: [id])
  inputs       ActivityInput[]

  @@index([type])
  @@index([productionId])
  @@index([userId])
  @@map("production_activities")
}

model ActivityInput {
  id         Int                @id @default(autoincrement())
  activityId Int
  name       String
  quantity   String
  unit       String
  cost       Float?
  activity   ProductionActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("activity_inputs")
}

model ProductionIssue {
  id           Int           @id @default(autoincrement())
  productionId String
  issueDate    DateTime      @db.Date
  type         IssueType
  description  String
  severity     IssueSeverity
  actions      String
  resolved     Boolean       @default(false)
  resolvedDate DateTime?     @db.Date
  cost         Float?
  production   Production    @relation(fields: [productionId], references: [id])

  @@index([type])
  @@index([severity])
  @@index([resolved])
  @@index([productionId])
  @@map("production_issues")
}

model WeatherData {
  id           Int        @id @default(autoincrement())
  productionId String
  recordDate   DateTime   @db.Date
  temperature  Float
  rainfall     Float
  humidity     Float
  windSpeed    Float?
  notes        String?
  source       String?
  production   Production @relation(fields: [productionId], references: [id])

  @@index([recordDate])
  @@index([productionId])
  @@map("weather_data")
}

model Contract {
  id               Int              @id @default(autoincrement())
  multiplierId     Int
  varietyId        Int
  startDate        DateTime         @db.Date
  endDate          DateTime         @db.Date
  seedLevel        SeedLevel
  expectedQuantity Int
  actualQuantity   Int?
  status           ContractStatus   @default(draft)
  parcelId         Int?
  paymentTerms     String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  multiplier       Multiplier       @relation(fields: [multiplierId], references: [id])
  variety          Variety          @relation(fields: [varietyId], references: [id])
  parcel           Parcel?          @relation(fields: [parcelId], references: [id])

  @@index([status])
  @@index([multiplierId])
  @@index([varietyId])
  @@map("contracts")
}

model Report {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  type        ReportType
  createdById Int
  fileName    String?
  filePath    String?
  parameters  Json?
  data        Json?
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   User       @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([createdById])
  @@index([isPublic])
  @@map("reports")
}

model SoilAnalysis {
  id            Int      @id @default(autoincrement())
  parcelId      Int
  analysisDate  DateTime @db.Date
  pH            Float?
  organicMatter Float?
  nitrogen      Float?
  phosphorus    Float?
  potassium     Float?
  notes         String?
  parcel        Parcel   @relation(fields: [parcelId], references: [id])

  @@index([parcelId])
  @@map("soil_analyses")
}

model PreviousCrop {
  id       Int      @id @default(autoincrement())
  parcelId Int
  cropType CropType
  variety  String?
  year     Int
  yield    Float?
  notes    String?
  parcel   Parcel   @relation(fields: [parcelId], references: [id])

  @@index([parcelId])
  @@index([year])
  @@map("previous_crops")
}

model ProductionHistory {
  id           Int        @id @default(autoincrement())
  multiplierId Int
  varietyId    Int
  seedLevel    SeedLevel
  season       String
  year         Int
  quantity     Int
  qualityScore Float?
  multiplier   Multiplier @relation(fields: [multiplierId], references: [id])
  variety      Variety    @relation(fields: [varietyId], references: [id])

  @@index([multiplierId])
  @@index([varietyId])
  @@index([year])
  @@map("production_history")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}