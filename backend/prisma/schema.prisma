// ✅ MODÈLES avec enums unifiés
model User {
  id              Int                  @id @default(autoincrement())
  name            String
  email           String               @unique
  password        String
  avatar          String?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  role            Role                 // ✅ Utilise enum unifié
  activities      ProductionActivity[]
  qualityControls QualityControl[]
  reports         Report[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Variety {
  id             Int        @id @default(autoincrement())
  name           String
  description    String?
  maturityDays   Int
  yieldPotential Float?
  resistances    String[]
  origin         String?
  releaseYear    Int?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  code           String     @unique
  cropType       CropType   // ✅ Utilise enum unifié
  contracts      Contract[]
  seedLots       SeedLot[]

  @@index([cropType])
  @@index([isActive])
  @@index([code])
  @@map("varieties")
}

model SeedLot {
  id              String           @id
  quantity        Int
  productionDate  DateTime         @db.Date
  expiryDate      DateTime?        @db.Date
  multiplierId    Int?
  parcelId        Int?
  batchNumber     String?
  parentLotId     String?
  notes           String?
  qrCode          String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  varietyId       Int
  level           SeedLevel        // ✅ Utilise enum unifié
  status          LotStatus        @default(pending) // ✅ Utilise enum unifié
  productions     Production[]
  qualityControls QualityControl[]
  multiplier      Multiplier?      @relation(fields: [multiplierId], references: [id])
  parcel          Parcel?          @relation(fields: [parcelId], references: [id])
  parentLot       SeedLot?         @relation("SeedLotGenealogy", fields: [parentLotId], references: [id])
  childLots       SeedLot[]        @relation("SeedLotGenealogy")
  variety         Variety          @relation(fields: [varietyId], references: [id])

  @@index([varietyId])
  @@index([status])
  @@index([level])
  @@map("seed_lots")
}

model QualityControl {
  id              Int        @id @default(autoincrement())
  lotId           String
  controlDate     DateTime   @db.Date
  germinationRate Float
  varietyPurity   Float
  moistureContent Float?
  seedHealth      Float?
  observations    String?
  inspectorId     Int
  testMethod      String?
  laboratoryRef   String?
  certificateUrl  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  result          TestResult // ✅ Utilise enum unifié
  inspector       User       @relation(fields: [inspectorId], references: [id])
  seedLot         SeedLot    @relation(fields: [lotId], references: [id])

  @@index([result])
  @@index([lotId])
  @@map("quality_controls")
}

