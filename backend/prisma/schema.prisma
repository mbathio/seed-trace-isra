// Schémas de base - pas de transformation
export const paginationSchema = z.object({
  page: z.union([z.string(), z.number()]).transform((val) => {
    const num = typeof val === "string" ? parseInt(val, 10) : val;
    return Math.max(1, isNaN(num) ? 1 : num);
  }),
  pageSize: z.union([z.string(), z.number()]).transform((val) => {
    const num = typeof val === "string" ? parseInt(val, 10) : val;
    return Math.min(Math.max(1, isNaN(num) ? 10 : num), 100);
  }),
  search: z.string().optional(),
  sortBy: z.string().max(50).optional(),
  sortOrder: z.enum(["asc", "desc"]).optional(),
});

export const emailSchema = z.string().email("Email invalide").toLowerCase();
export const phoneSchema = z.string().regex(/^(\+221)?[0-9]{8,9}$/, "Téléphone invalide").optional();
export const percentageSchema = z.number().min(0).max(100);
export const positiveIdSchema = z.union([
  z.number().positive(),
  z.string().transform((val) => {
    const parsed = parseInt(val, 10);
    if (isNaN(parsed) || parsed <= 0) throw new Error("ID invalide");
    return parsed;
  }),
]);

// 4. backend/src/services/SeedLotService.ts - VERSION SANS TRANSFORMATEURS
import { prisma } from "../config/database";
import { logger } from "../utils/logger";
import { LotStatus, SeedLevel } from "../config/enums";
import type { PaginationQuery } from "../types/api";

export class SeedLotService {
  // ✅ PAS DE TRANSFORMATION - utilise directement les valeurs Prisma/UI
  static async createSeedLot(data: any): Promise<any> {
    try {
      // Validation simple sans transformation
      if (data.status && !Object.values(LotStatus).includes(data.status)) {
        throw new Error(`Statut invalide: ${data.status}`);
      }
      
      if (data.level && !Object.values(SeedLevel).includes(data.level)) {
        throw new Error(`Niveau invalide: ${data.level}`);
      }

      const seedLot = await prisma.seedLot.create({
        data: {
          ...data,
          // Pas de transformation nécessaire
        },
        include: {
          variety: true,
          multiplier: true,
          parcel: true,
        },
      });

      return seedLot; // ✅ Retour direct sans transformation
    } catch (error) {
      logger.error("Erreur création lot:", error);
      throw error;
    }
  }

  static async getSeedLots(filters: any): Promise<any> {
    try {
      const where: any = { isActive: true };

      // ✅ Filtres directs sans transformation
      if (filters.status) where.status = filters.status;
      if (filters.level) where.level = filters.level;
      if (filters.varietyId) where.varietyId = filters.varietyId;

      const seedLots = await prisma.seedLot.findMany({
        where,
        include: {
          variety: true,
          multiplier: true,
          parcel: true,
          qualityControls: {
            orderBy: { controlDate: "desc" },
            take: 1,
          },
        },
        orderBy: { createdAt: "desc" },
        skip: ((filters.page || 1) - 1) * (filters.pageSize || 10),
        take: filters.pageSize || 10,
      });

      const total = await prisma.seedLot.count({ where });

      return {
        success: true,
        message: "Lots récupérés",
        data: seedLots, // ✅ Pas de transformation
        meta: {
          total,
          page: filters.page || 1,
          pageSize: filters.pageSize || 10,
          totalPages: Math.ceil(total / (filters.pageSize || 10)),
        },
      };
    } catch (error) {
      logger.error("Erreur récupération lots:", error);
      throw error;
    }
  }

  static async updateSeedLot(id: string, data: any): Promise<any> {
    try {
      // Validation simple
      if (data.status && !Object.values(LotStatus).includes(data.status)) {
        throw new Error(`Statut invalide: ${data.status}`);
      }

      const updatedLot = await prisma.seedLot.update({
        where: { id },
        data, // ✅ Pas de transformation
        include: {
          variety: true,
          multiplier: true,
          parcel: true,
        },
      });

      return updatedLot; // ✅ Retour direct
    } catch (error) {
      logger.error("Erreur mise à jour lot:", error);
      throw error;
    }
  }
}

